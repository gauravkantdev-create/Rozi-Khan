# ==========================================
# RoziKhan Python FastAPI Backend Configuration
# ==========================================

PORT=5000
NODE_ENV=development

# PostgreSQL Connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rozikhan

# JWT Authentication Config
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET=supersecretjwttokenforrozikhanapplicationdevelopment

# Resend API (For OTP email verification)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=RoziKhan <onboarding@resend.dev>

# Razorpay Payment Gateway Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

# MongoDB Atlas URL (Required ONLY for the migrations/002_mongo_to_postgres.py script)
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/test?retryWrites=true&w=majority
MONGO_DB_NAME=test
