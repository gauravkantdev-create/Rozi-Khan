# Copy this file to `.env` in the backend folder.
# Use the SAME MONGO_URI as Render so localhost and Vercel share one database.

PORT=5000
NODE_ENV=development

# MongoDB Atlas — use the SAME MONGO_URI on Render as localhost
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
# Must match on Render too (local users live in "test" unless you chose another name)
MONGO_DB_NAME=test

JWT_SECRET=your_long_random_secret

# Resend (copy from Render)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=RoziKhan <onboarding@resend.dev>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
